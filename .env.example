# ─── Environment Variables ────────────────────────────────────────────────────
#
# IMPORTANT: .env.local is for LOCAL DEV ONLY.
# NEVER put production or preview credentials in .env.local.
# NEVER run `vercel env pull` into .env.local — it dumps production secrets.
#
# Environment strategy:
#   Local dev  → .env.local (committed as dev-safe defaults, no remote DB)
#   Preview    → Vercel dashboard (Preview scope only)
#   Production → Vercel dashboard (Production scope only)
#
# To target a remote DB from local machine (e.g., seeding preview):
#   TURSO_DATABASE_URL=... TURSO_AUTH_TOKEN=... npm run db:seed

# Generate with: npx auth secret
AUTH_SECRET=

# Set to true when deploying behind a proxy (e.g. Vercel)
# AUTH_TRUST_HOST=true

# Discord OAuth — https://discord.com/developers/applications
# Auth.js auto-reads AUTH_<PROVIDER>_ID / AUTH_<PROVIDER>_SECRET at request time
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Riot Games API — https://developer.riotgames.com
RIOT_API_KEY=

# Turso Database (optional — defaults to local SQLite file)
# For production/preview: set in Vercel dashboard, NOT here
# For local dev: leave unset (defaults to file:./data/lol-tracker.db)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Demo / Preview Mode ─────────────────────────────────────────────────────
# Set to "true" to enable demo mode:
#   - Fake auth (no Discord OAuth required)
#   - Riot API mocking (no API key required)
#   - Login page shows a user picker instead of Discord sign-in
#
# Usage:
#   1. Set NEXT_PUBLIC_DEMO_MODE=true in .env.local
#   2. Seed data:   npm run db:seed  (creates tables + inserts demo data)
#   3. Start dev:   npm run dev
#
# NEXT_PUBLIC_DEMO_MODE=true
