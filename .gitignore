# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
tests/smoke/setup/.auth/
.playwright-mcp/

# temporary screenshots (audit, annotations, etc.)
/screenshots/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
nul

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# temporary PR body files (generated during PR description updates)
pr*_body*.txt

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local database
/data/*.db
/data/*.db-wal
/data/*.db-shm
.env*.local
..env.local.un~

# NOTE: public/assets/ddragon/ is NOT ignored — these are generated by
# scripts/optimize-ddragon.ts but intentionally committed for zero-build-time
# image serving. Updated via the ddragon-assets GitHub Action.
